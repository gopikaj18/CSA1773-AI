import heapq

graph = {'A':[('B',1),('C',3)],
         'B':[('D',1)],
         'C':[('D',1)],
         'D':[]}

h = {'A':3,'B':1,'C':1,'D':0}

def astar(start, goal):
    pq = [(0,start)]
    visited = set()

    while pq:
        cost,node = heapq.heappop(pq)
        if node == goal:
            print("Reached")
            return
        visited.add(node)

        for n,w in graph[node]:
            if n not in visited:
                heapq.heappush(pq,(cost+w+h[n],n))

astar('A','D')
