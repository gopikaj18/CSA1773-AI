def alphabeta(depth, alpha, beta, maxPlayer):
    if depth==0:
        return 0

    if maxPlayer:
        val = -999
        val = max(val, alphabeta(depth-1,alpha,beta,False))
        alpha = max(alpha,val)
        if beta<=alpha:
            return val
        return val
    else:
        val = 999
        val = min(val, alphabeta(depth-1,alpha,beta,True))
        beta = min(beta,val)
        if beta<=alpha:
            return val
        return val
